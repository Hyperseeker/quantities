{
	"name": "@quantities/core",
	"version": "2.0.0",
	"description": "TypeScript library for quantity calculation and unit conversion",
	"keywords": [
		"conversion",
		"convert",
		"imperial",
		"measure",
		"measurement",
		"metric",
		"parse",
		"parser",
		"physical",
		"quantities",
		"quantity",
		"temperature",
		"unit",
		"units"
	],
	"homepage": "https://github.com/Hyperseeker/quantities",
	"bugs": {
		"url": "https://github.com/Hyperseeker/quantities/issues"
	},
	"license": "MIT",
	"author": "Steve Brand <thatfanficguy@protonmail.com>",
	"contributors": [
		"Steve Brand <thatfanficguy@protonmail.com>",
		"Julien Sanchez <julien.sanchez@gmail.com>",
		"Rage Shadowman <ralph@crc-corp.com>"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Hyperseeker/quantities.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/quantities.js",
	"module": "./dist/quantities.js",
	"types": "./dist/quantities.d.ts",
	"exports": {
		".": {
			"types": "./dist/quantities.d.ts",
			"default": "./dist/quantities.js"
		}
	},
	"scripts": {
		"build": "tsgo -b",
		"typecheck": "tsgo --noEmit",
		"test": "bun test",
		"lint": "oxlint --type-aware .",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"prepublishOnly": "bun run build"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14"
	}
}
