{
	"name": "@quantities/registry",
	"version": "1.0.0",
	"description": "Custom registry support for @quantities/core",
	"keywords": [
		"conversion",
		"convert",
		"imperial",
		"measure",
		"measurement",
		"metric",
		"parse",
		"parser",
		"physical",
		"quantities",
		"quantity",
		"temperature",
		"unit",
		"units"
	],
	"homepage": "https://github.com/Hyperseeker/quantities",
	"bugs": {
		"url": "https://github.com/Hyperseeker/quantities/issues"
	},
	"license": "MIT",
	"author": "Steve Brand <thatfanficguy@protonmail.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/Hyperseeker/quantities.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsgo -b",
		"typecheck": "tsgo --noEmit",
		"test": "bun test",
		"lint": "oxlint --type-aware",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"prepublishOnly": "bun run build"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14"
	},
	"peerDependencies": {
		"@quantities/core": "^2.0.0"
	}
}
